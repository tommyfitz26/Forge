# Copy to .env.local and fill in. .env.local is gitignored.
# Values validated by lib/env.ts at startup via Zod — app crashes on invalid/missing required vars.

# --- Supabase (required) ---
# URL + anon key are NEXT_PUBLIC_ so the browser client can bundle them.
# Anon key is public by design; RLS is the security boundary.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Owner (required) ---
# The single allowed login email. All non-matching sessions are destroyed by middleware.
OWNER_EMAIL=you@example.com

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=

# --- OpenAI (required; Whisper only) ---
OPENAI_API_KEY=

# --- Resend (Phase 3) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=forge@you.com

# --- QStash (Phase 2) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Web Push (Phase 3) — generate via `npx web-push generate-vapid-keys` ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Shortcut auth (required) — long random Bearer embedded in the iOS Shortcut ---
# Generate one (64 hex chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Same value goes in Vercel env (Production + Preview + Development) AND in the
# Shortcut's "Get Contents of URL" Authorization header. See README → iOS Shortcut.
SHORTCUT_API_TOKEN=

# --- App (required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Sentry (optional; wiring is no-op until DSN is set) ---
# Server-side DSN. Can be the same as NEXT_PUBLIC_SENTRY_DSN in practice.
SENTRY_DSN=
# Client-side DSN (must have NEXT_PUBLIC_ prefix to reach the browser bundle).
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload credentials — only needed when doing a release build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Scheduling (§4.4) — single constant; no per-user timezone in v1 ---
APP_SCHEDULE_TZ=America/New_York

# --- Budgets ---
# MAX_MONTHLY_COST_USD — hard pre-call check in the task runner (§11.2); calls abort if exceeded.
# MAX_RESEARCH_COST_USD — documentation/alerting only; per-research cost is bounded by max_tokens + max_uses (§4.3).
MAX_MONTHLY_COST_USD=25
MAX_RESEARCH_COST_USD=0.25
