{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:types": "supabase gen types typescript --linked --schema public 2>/dev/null > lib/types/db.ts",
    "db:push": "supabase db push",
    "db:new": "supabase migration new",
    "jobs:sync": "node --env-file=.env.local --import tsx scripts/register-qstash-schedules.ts",
    "jobs:sync:dry": "node --env-file=.env.local --import tsx scripts/register-qstash-schedules.ts --dry-run",
    "jobs:sync:prune": "node --env-file=.env.local --import tsx scripts/register-qstash-schedules.ts --prune"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.51.0",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@upstash/qstash": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "marked": "^18.0.2",
    "next": "16.2.4",
    "openai": "^6.34.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "serwist": "^9.5.7",
    "tailwind-merge": "^2.6.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
